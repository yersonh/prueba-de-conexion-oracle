{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "buildCommand": null
  },
  "deploy": {
    "startCommand": null,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/index.php",
    "healthcheckTimeout": 30,
    "numReplicas": 1
  },
  "volumes": [
    {
      "path": "/var/www/html/uploads",
      "name": "uploads"
    }
  ]
}